# ==============================================
# Krayin CRM - Production Environment Variables
# ==============================================
# Copy to .env and configure for production
# ==============================================

APP_NAME='Krayin CRM'
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://your-domain.com
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_CURRENCY=USD

# Database
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=krayin_crm
DB_USERNAME=krayin
DB_PASSWORD=changeme_strong_password_here
DB_PREFIX=

# Cache & Queue
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# Redis (optional)
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail (configure según provider)
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=noreply@your-domain.com
MAIL_PASSWORD=changeme
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@your-domain.com
MAIL_FROM_NAME="${APP_NAME}"

# Security
SESSION_SECURE_COOKIE=true
SANCTUM_STATEFUL_DOMAINS=your-domain.com

# Logging
LOG_CHANNEL=stderr
LOG_LEVEL=warning